  summarise(
    Mean_Estimate = mean(Estimate),
    True_Value = mean(True_Val),
    Bias = mean(Estimate - True_Val),
    RMSE = sqrt(mean((Estimate - True_Val)^2)),
    SD = sd(Estimate)
  )

print(summary_stats)

# Plot 1: Distribution of Estimates
