adult <- fread("adult.data.txt", header = FALSE, col.names = c(
  "age", "workclass", "fnlwgt", "education", "education_num", "marital_status",
  "occupation", "relationship", "race", "sex", "capital_gain", "capital_loss",
  "hours_per_week", "native_country", "income"
))

adult$Y <- ifelse(trimws(adult$income) == ">50K", 1, 0)
adult$T_obs <- ifelse(adult$education_num >= 13, 1, 0)

X_cols <- c("age", "education_num", "capital_gain",
            "capital_loss", "hours_per_week")

adult_scaled <- adult %>%
  dplyr::mutate(across(dplyr::all_of(X_cols), scale)) %>%
  dplyr::select(Y, T_obs, dplyr::all_of(X_cols)) %>%
  na.omit()

# Convert to data.table (important for ..X_cols syntax)
adult_scaled <- as.data.table(adult_scaled)

# ==========================================================
# 2️⃣ Simulation Function
# ==========================================================
run_single_sim <- function(iter_id) {
  
  set.seed(1000 + iter_id)
  
  # Bootstrap sample
  df <- adult_scaled[sample(.N, size = 800, replace = TRUE)]
  
  Y <- df$Y
  T_obs <- df$T_obs
  
  # FIX: correct data.table column selection
  X <- as.matrix(df[, ..X_cols])
  storage.mode(X) <- "double"
  
  # ------------------------------
  # Propensity model
  # ------------------------------
  prop_mod <- glm(T_obs ~ ., 
                  data = as.data.frame(df[, c("T_obs", X_cols), with = FALSE]),
                  family = binomial())
  
  pi_hat <- predict(prop_mod, type = "response")
  pi_hat <- pmin(pmax(pi_hat, 0.05), 0.95)
  
  # ------------------------------
  # True value proxy
  # ------------------------------
  full_mod <- glm(Y ~ T_obs + ., 
                  data = as.data.frame(df),
                  family = binomial())
  
  df1 <- copy(df)
  df1$T_obs <- 1
  
  true_val <- mean(predict(full_mod,
                           newdata = as.data.frame(df1),
                           type = "response"))
  
  # ------------------------------
  # Outcome model
  # ------------------------------
  out_mod <- glm(Y ~ ., 
                 data = as.data.frame(df),
                 family = binomial())
  
  m_hat <- predict(out_mod, type = "response")
  
  # ======================================================
  # Neural Network
  # ======================================================
  fit_nn <- function(layers_list, dropout = 0, l2 = 0) {
    
    mod <- keras_model_sequential()
    
    for(i in 1:length(layers_list)) {
      
      reg <- if(l2 > 0) regularizer_l2(l2) else NULL
      
      mod %>%
        layer_dense(
          units = layers_list[i],
          activation = "relu",
          input_shape = if(i == 1) ncol(X) else NULL,
          kernel_regularizer = reg
        )
      
      if(dropout > 0)
        mod %>% layer_dropout(rate = dropout)
    }
    
    mod %>% layer_dense(1, activation = "sigmoid")
    
    mod %>% compile(
      optimizer = "adam",
      loss = "binary_crossentropy"
    )
    
    mod %>% fit(X, Y,
                epochs = 15,
                batch_size = 32,
                verbose = 0)
    
    preds <- predict(mod, X)
    k_clear_session()
    
    return(mean(preds))
  }
  
  # ======================================================
  # Estimators
  # ======================================================
  HT <- mean((T_obs * Y) / pi_hat)
  
  Hajek <- sum((T_obs * Y) / pi_hat) /
    sum(T_obs / pi_hat)
  
  DR <- mean(m_hat +
               (T_obs * (Y - m_hat)) / pi_hat)
  
  FNN        <- fit_nn(c(64, 32))
  Deep_NN    <- fit_nn(c(128, 64, 32))
  Dropout_NN <- fit_nn(c(64, 32), dropout = 0.3)
  L2_NN      <- fit_nn(c(64, 32), l2 = 0.001)
  
  res <- c(
    HT = HT,
    Hajek = Hajek,
    DR_GLM = DR,
    FNN = FNN,
    Deep_NN = Deep_NN,
    Dropout_NN = Dropout_NN,
    L2_NN = L2_NN
  )
  
  data.frame(
    Method = names(res),
    Estimate = res,
    True_Val = true_val,
    Iter = iter_id
  )
}

# ==========================================================
# 3️⃣ Run 100 Simulations
# ==========================================================
n_sims <- 100

results_all <- rbindlist(lapply(1:n_sims, function(i) {
  if(i %% 10 == 0) cat("Iteration:", i, "\n")
