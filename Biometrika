# ==========================================================
# 2️⃣ Simulation Function (100 Iterations)
# ==========================================================
run_iteration <- function(iter_id) {
  # Subsample for variance
  set.seed(123 + iter_id)
  d_sub <- adult_scaled[sample(1:nrow(adult_scaled), 1000), ]
  X_mat <- as.matrix(d_sub[, ..X_cols])
  
  # --- Step A: Propensity Score (g-model) ---
  g_mod <- glm(T_obs ~ age + education_num + capital_gain, 
               data = d_sub, family = binomial())
  pi_hat <- predict(g_mod, type = "response")
  pi_hat <- pmax(pmin(pi_hat, 0.95), 0.05) # Positivity bounding
  
  # --- Step B: Outcome Model (Q-model) ---
  q_mod <- glm(Y ~ T_obs + age + education_num + capital_gain, 
               data = d_sub, family = binomial())
  
  # Counterfactual: What if everyone was Treated (T=1)?
  d_treated <- d_sub; d_treated$T_obs <- 1
  Q1 <- predict(q_mod, newdata = d_treated, type = "response")
  # Initial prediction for observed state
  Q_obs <- predict(q_mod, type = "response")
  
  # --- Step C: TMLE Update ---
  # Calculate "Clever Covariate"
  H1 <- d_sub$T_obs / pi_hat
  # Fluctuation step
  eps <- glm(d_sub$Y ~ -1 + H1, offset = qlogis(Q_obs), family = binomial())$coefficients
  # Targeted counterfactual prediction
  Q1_star <- plogis(qlogis(Q1) + eps * (1/pi_hat))
  
  # --- Step D: Neural Network Logic ---
  fit_nn <- function(nodes, drop = 0) {
    k_clear_session()
    model <- keras_model_sequential() %>%
      layer_dense(nodes[1], activation="relu", input_shape=ncol(X_mat)) %>%
      layer_dense(nodes[2], activation="relu") %>%
      layer_dense(1, activation="sigmoid")
    model %>% compile(optimizer="adam", loss="binary_crossentropy")
    model %>% fit(X_mat, d_sub$Y, epochs=10, verbose=0)
    return(mean(predict(model, X_mat)))
  }
  
  # --- Aggregate results ---
  target_mask <- (d_sub$T_obs == 1)
  data.frame(
    Iter = iter_id,
    Method = c("HT", "Hajek", "DR (GLM)", "TMLE", "FNN", "Deep NN"),
    Estimate = c(
      mean((target_mask * d_sub$Y) / pi_hat),
      sum((target_mask * d_sub$Y) / pi_hat) / sum(target_mask / pi_hat),
      mean(Q_obs + (target_mask * (d_sub$Y - Q_obs)) / pi_hat),
      mean(Q1_star),
      fit_nn(c(64, 32)),
      fit_nn(c(128, 64))
    )
  )
}

