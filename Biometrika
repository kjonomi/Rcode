# ==========================================================
# 1️⃣ Simulation Function
# ==========================================================
run_single_sim <- function(iter_id) {
  set.seed(123 + iter_id) # Unique but reproducible seed per run
  
  # --- Data Generation ---
  n <- 800
  num_features <- 12
  num_blocks <- 6
  K <- 4
  
  block_id <- sample(1:num_blocks, n, replace=TRUE)
  X_num <- matrix(rnorm(n * num_features), n, num_features)
  colnames(X_num) <- paste0("f", 1:num_features)
  
  all_combos <- as.matrix(expand.grid(replicate(K, c(0,1), simplify=FALSE)))
  num_t <- nrow(all_combos)
  target_t <- num_t
  
  block_treat_map <- lapply(1:num_blocks, function(x) {
    c(target_t, sample(setdiff(1:num_t, target_t), 5))
  })
  
  T_idx_obs <- sapply(block_id, function(b) sample(block_treat_map[[b]], 1))
  T_mat <- all_combos[T_idx_obs, ]
  block_sizes <- sapply(block_treat_map, length)
  pi_it <- 1 / block_sizes[block_id]
  
  # --- Complex DGP ---
  X_quad <- X_num^2
  X_sin  <- sin(X_num)
  X_inter <- NULL
  for(i in 1:5) {
    for(j in (i+1):5) { X_inter <- cbind(X_inter, X_num[,i]*X_num[,j]) }
  }
  X_design <- cbind(X_num, X_quad, X_sin, X_inter)
  
  beta <- runif(ncol(X_design), -0.5, 0.5)
  tau_main <- runif(K, 0.2, 0.8)
  tau_cate <- matrix(runif(ncol(X_design)*K, -0.3, 0.3), ncol=K)
  
  lin_stage1 <- X_design %*% beta + T_mat %*% tau_main
  cate_effect <- rowSums(X_design * tau_cate[,1])
  linear_pred <- lin_stage1 + cate_effect + T_mat %*% tau_main
  prob <- 1/(1+exp(-linear_pred))
  Y <- rbinom(n, 1, prob)
  
  # --- True Target Value ---
  t_effect <- as.numeric(all_combos[target_t,] %*% tau_main)
  true_val <- mean(1/(1+exp(-(X_design %*% beta + t_effect))))
  
  # --- Modeling ---
  df <- data.frame(Y=Y, X_design, T_idx=factor(T_idx_obs))
  glm_mod <- glm(Y~., data=df, family=binomial())
  m_hat <- predict(glm_mod, newdata=df, type="response")
  
  X_nn <- as.matrix(X_design)
  storage.mode(X_nn) <- "double"
  
  # Helper to build/train/predict Keras
  fit_nn <- function(layers_list, dropout=0, l2=0) {
    mod <- keras_model_sequential()
    for(i in 1:length(layers_list)) {
      reg <- if(l2 > 0) regularizer_l2(l2) else NULL
      mod %>% layer_dense(layers_list[i], activation="relu", 
                          input_shape=if(i==1) ncol(X_nn) else NULL,
                          kernel_regularizer=reg)
      if(dropout > 0) mod %>% layer_dropout(dropout)
    }
    mod %>% layer_dense(1, activation="sigmoid")
    mod %>% compile(optimizer="adam", loss="binary_crossentropy")
    mod %>% fit(X_nn, Y, epochs=15, verbose=0)
    res <- predict(mod, X_nn)
    k_clear_session() # Critical for memory
    return(mean(res))
  }
  
  # Gather Estimates
  res_list <- list(
    "HT"         = mean(((T_idx_obs==target_t)*Y)/pi_it),
    "Hajek"      = sum(((T_idx_obs==target_t)*Y)/pi_it) / sum((T_idx_obs==target_t)/pi_it),
    "DR_GLM"     = mean(m_hat + ((T_idx_obs==target_t)*(Y-m_hat))/pi_it),
    "FNN"        = fit_nn(c(64, 32)),
    "Deep_NN"    = fit_nn(c(128, 64, 32)),
    "Dropout_NN" = fit_nn(c(64, 32), dropout=0.3),
    "L2_NN"      = fit_nn(c(64, 32), l2=0.001)
  )
  
  return(data.frame(Method = names(res_list), 
                    Estimate = unlist(res_list), 
                    True_Val = true_val,
                    Iter = iter_id))
}

# ==========================================================
# 2️⃣ Execute Loop (100 Times)
# ==========================================================
n_sims <- 100
results_all <- lapply(1:n_sims, function(i) {
  if(i %% 10 == 0) cat("Starting Iteration:", i, "\n")
  run_single_sim(i)
}) %>% bind_rows()

# ==========================================================
