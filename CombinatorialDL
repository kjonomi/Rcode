  theme_minimal(base_size = 14) +
  labs(
    title = "Distribution of Estimated Treatment Effects (蟿)",
    x = "Estimated 蟿(x)",
    y = "Density"
  ) +
  geom_vline(xintercept = 1.5, linetype = "dashed")

eval_table <- data.frame(
  Model = c("CCDN", "CausalForest", "TARNet"),
  Bias = c(
    mean(tau_ccdn - tau_true),
    mean(tau_cf - tau_true),
    mean(tau_tarnet - tau_true)
  )
)

ggplot(eval_table, aes(x = Model, y = Bias, fill = Model)) +
