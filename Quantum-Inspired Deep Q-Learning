ReplayBuffer <- R6Class(
  "ReplayBuffer",
  public = list(
    capacity = NULL,
    buffer = NULL,
    position = 1,
    initialize = function(capacity) {
      self$capacity <- capacity
      self$buffer <- vector("list", capacity)
    },
    push = function(state, action, reward) {
      self$buffer[[self$position]] <- list(state = state, action = action, reward = reward)
      self$position <- ifelse(self$position == self$capacity, 1, self$position + 1)
    },
    sample_indices = function(batch_size, weights = NULL) {
      filled <- which(!sapply(self$buffer, is.null))
      if(length(filled) < batch_size) return(NULL)
      
      if(is.null(weights)) {
        return(sample(filled, batch_size))
      } else {
        # Ensure weights match filled buffer length
        w <- weights[filled]
        return(sample(filled, batch_size, prob = w/sum(w)))
      }
    }
  )
)

############################
# 3️⃣ Model & Uncertainty
############################
build_model <- function(input_shape) {
  model <- keras_model_sequential() %>%
    layer_conv_1d(filters = 32, kernel_size = 3, activation = "relu", input_shape = input_shape) %>%
    layer_lstm(units = 32) %>%
    layer_dense(units = 64, activation = "relu") %>%
    layer_dense(units = 3) # 3 Actions
  
  model %>% compile(optimizer = optimizer_adam(learning_rate = 0.001), loss = "mse")
  return(model)
}

############################
# 4️⃣ Training Function
############################
train_dqn <- function(X, Y, episodes=50, batch_size=32, method="uniform", alpha=0.5) {
  input_dims <- dim(X)[2:3]
  model <- build_model(input_dims)
  buffer <- ReplayBuffer$new(2000)
  epsilon <- 1.0
  
  for(ep in 1:episodes) {
    # 1. Collect Experience
    for(i in 1:dim(X)[1]) {
      state <- X[i,,]
      if(runif(1) < epsilon) {
        action <- sample(0:2, 1)
      } else {
        q_vals <- predict(model, array(state, dim=c(1, input_dims)), verbose=0)
        action <- which.max(q_vals) - 1
      }
      reward <- Y[i, action + 1]
      buffer$push(state, action, reward)
    }
    
    # 2. Sample and Train
    filled_idx <- which(!sapply(buffer$buffer, is.null))
    if(length(filled_idx) < batch_size) next
    
    # Calculate Sampling Weights
    weights <- rep(1, length(filled_idx))
    if(method != "uniform") {
      # Extract states for weighting
      all_s <- array(0, dim=c(length(filled_idx), input_dims))
      for(k in seq_along(filled_idx)) all_s[k,,] <- buffer$buffer[[filled_idx[k]]]$state
      
      q_all <- predict(model, all_s, verbose=0)
      
      if(method == "entropy") {
        prob <- t(apply(q_all, 1, function(x) exp(x)/sum(exp(x))))
        entropy <- -rowSums(prob * log(prob + 1e-8))
        qvar <- apply(q_all, 1, var)
        weights <- alpha * entropy + (1-alpha) * qvar
      } else if(method == "per") {
        # Simple TD Error weighting
        actual_rewards <- sapply(filled_idx, function(idx) buffer$buffer[[idx]]$reward)
        actual_actions <- sapply(filled_idx, function(idx) buffer$buffer[[idx]]$action)
        pred_val <- q_all[cbind(1:nrow(q_all), actual_actions + 1)]
        weights <- abs(actual_rewards - pred_val) + 1e-5
      }
    }
    
    # Perform Sample
    idx <- buffer$sample_indices(batch_size, weights)
    samples <- buffer$buffer[idx]
    
    batch_s <- array(0, dim=c(batch_size, input_dims))
    batch_y <- matrix(0, nrow=batch_size, ncol=3)
    
    for(j in 1:batch_size) {
      batch_s[j,,] <- samples[[j]]$state
      current_q <- predict(model, array(samples[[j]]$state, dim=c(1, input_dims)), verbose=0)
      current_q[1, samples[[j]]$action + 1] <- samples[[j]]$reward
      batch_y[j,] <- current_q
    }
    
    model %>% fit(batch_s, batch_y, epochs=1, verbose=0)
    epsilon <- max(0.1, epsilon * 0.95)
  }
  return(model)
}

evaluate_model <- function(model, X, Y_true) {
  q_preds <- predict(model, X, verbose=0)
  actions <- apply(q_preds, 1, which.max)
  rewards <- sapply(1:nrow(Y_true), function(i) Y_true[i, actions[i]])
  return(mean(rewards))
}

