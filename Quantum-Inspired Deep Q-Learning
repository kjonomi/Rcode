logits <- cbind(3.5 * rm_avg, 3.5 * ptratio_avg, -3.5 * rm_avg)
exp_logits <- exp(logits)
prob_mat <- exp_logits / rowSums(exp_logits)
W <- apply(prob_mat, 1, function(p) sample(0:2, 1, prob = p))

